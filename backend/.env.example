# ============================================================================
# NerveCore Environment Configuration Template
# Copy this file to '.env' and fill in your actual credentials.
# ============================================================================

# --- Supabase Database Configuration ---
# Use the credentials from your Supabase Project Settings (Settings -> Database)
# Host format: db.dutokzmphzycqpxsjler.supabase.co
DB_HOST=db.dutokzmphzycqpxsjler.supabase.co
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=YOUR_SUPABASE_DATABASE_PASSWORD
DB_NAME=postgres

# --- NVIDIA NIM Configurations ---
# Required for Llama 3.3 orchestration & LLM tool routing
NVIDIA_API_KEY=YOUR_NVIDIA_NIM_API_KEY
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_LLM_MODEL=meta/llama-3.3-70b-instruct

# --- Embedding NIM Configuration ---
NVIDIA_EMBEDDING_MODEL=nvidia/embeddings-nv-embed-qa-4
EMBEDDING_DIMENSION=1024

# --- NVIDIA Riva ASR (Speech-to-Text) ---
RIVA_SERVER_ADDRESS=localhost:50051
RIVA_LANGUAGE_CODE=en-US

# --- Security ---
API_SECRET_KEY=nervecore-super-secure-local-secret-key-12345
