# ============================================================================
# Cortex Enterprise Backend Environment Configurations
# ============================================================================

PORT=8000

# Supabase Configurations
# Find these under Settings -> API in your Supabase dashboard
SUPABASE_URL=https://dutokzmphzycqpxsjler.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# NVIDIA NIM API Configuration
# Get your API key from NVIDIA Build portal (integrate.api.nvidia.com)
NVIDIA_BUILD_API_KEY=YOUR_NVIDIA_BUILD_API_KEY
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_LLM_MODEL=meta/llama-3.3-70b-instruct
NVIDIA_EMBEDDING_MODEL=nvidia/nv-embedqa-e5-v5
EMBEDDING_DIMENSION=1024
